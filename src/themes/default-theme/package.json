		"autoprefixer": "^10.4.21",
		"cssnano": "^7.1.1",
		"lefthook": "^1.13.2",
		"postcss": "^8.5.6",
		"postcss-combine-duplicated-selectors": "^10.0.3",
		"postcss-preset-env": "^10.4.0",
		"slick-carousel": "^1.8.1",
		"tailwindcss": "^4.1.13",
		"typescript": "^5.9.2",
		"vite": "7.1.7",
		"vite-plugin-watch": "^0.3.1"
	},
	"dependencies": {
		"@tailwindcss/postcss": "^4.1.11",
