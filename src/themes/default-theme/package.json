{
  "name": "the-wordpress-theme",
  "private": true,
  "version": "0.0.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --emptyOutDir",
    "all": "run-s build sass:build",
    "watch": "vite build --watch",
    "preview": "vite preview",
    "browser-sync": "browser-sync start --reload-delay 100 --files './assets/**/*.ts' './assets/**/*.scss' './**/*.twig'",
    "sass:build": "sass assets/sass/main.scss:dist/styles.css && postcss dist/styles.css -o dist/styles.css",
    "sass:watch": "sass --watch assets/sass/main.scss:dist/styles.css && postcss dist/styles.css -o dist/styles.css",
    "format": "prettier --write \"**/*.scss\"",
    "format:check": "prettier --check \"**/*.scss\"",
    "stylelint:scss": "stylelint \"**/*.scss\"",
    "stylelint:scss:fix": "stylelint \"**/*.scss\" --fix"
  },
  "devDependencies": {
    "@rollup/plugin-inject": "^5.0.5",
    "@types/jquery": "^3.5.32",
    "@types/slick-carousel": "^1.6.40",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.20",
    "browser-sync": "^3.0.4",
    "cssnano": "^7.1.1",
    "cssnano-preset-lite": "^4.0.4",
    "jquery": "^3.7.1",
    "motion": "^12.23.3",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.0",
    "postcss-combine-duplicated-selectors": "^10.0.3",
    "postcss-import": "^16.1.0",
    "postcss-preset-env": "^10.4.0",
    "postcss-scss": "^4.0.9",
    "prettier": "3.8.1",
    "sass": "^1.83.4",
    "slick-carousel": "^1.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^7.0.1",
    "typescript": "^5.9.2",
    "vite": "8.0.5",
    "vite-plugin-static-copy": "^4.0.1",
    "vite-plugin-watch": "^0.3.1"
  }
}
